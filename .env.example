# App settings
APP_NAME=Premier League Analytics API
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
API_PREFIX=

# Server settings
HOST=127.0.0.1
PORT=8000

# PostgreSQL database URL used by SQLAlchemy
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/premier_league_analytics

# Comma-separated CORS origins for frontend apps
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# API key auth + in-memory rate limiting
API_KEY=change_me
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
